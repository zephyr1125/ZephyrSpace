# =========================
# Obsidian 本地工作区状态
# =========================

# 这些文件主要记录当前打开的标签页、侧边栏状态、最近访问文件等，
# 对知识库本身没有长期价值，而且多人或多设备下会频繁产生噪音。
.obsidian/workspace.json
.obsidian/graph.json

# =========================
# Obsidian 缓存与可再生文件
# =========================

# 如后续出现缓存目录，默认不纳入版本管理。
.obsidian/cache/

# =========================
# 自动化运行产物与临时文件
# =========================

# 保留日报正文，但忽略脚本运行日志、临时导出和抓取缓存。
logs/
tmp/
temp/
cache/
exports/
data/raw/
data/cache/
*.log

# 粗筛缓存与临时数据文件
data/cache_*.json
data/_screen_*.csv
data/screen_*.json
data/prebuy_*.json
data/temp_*.json

# 脚本目录下的临时数据与临时脚本
scripts/tmp_*.py
scripts/*_data.json

# 环境变量（含 API Token 等敏感信息）
.env
.env.*
!.env.example

# =========================
# Python 运行噪音
# =========================

__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.venv/
venv/

# =========================
# 系统文件
# =========================

.DS_Store
Thumbs.db
desktop.ini

